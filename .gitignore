# ============================================================
# Python virtual environment
# ============================================================

.venv/
venv/
env/


# ============================================================
# Python cache and compiled files
# ============================================================

__pycache__/
*.py[cod]
*$py.class


# ============================================================
# Test and coverage cache
# ============================================================

.pytest_cache/
.coverage
.coverage.*
htmlcov/


# ============================================================
# Type checker and linter cache
# ============================================================

.mypy_cache/
.ruff_cache/


# ============================================================
# Jupyter Notebook cache
# ============================================================

.ipynb_checkpoints/


# ============================================================
# Environment variables and secret files
# ============================================================

.env
.env.*
!.env.example


# ============================================================
# IDE and editor settings
# ============================================================

.vscode/
.idea/


# ============================================================
# Operating system files
# ============================================================

.DS_Store
Thumbs.db
desktop.ini


# ============================================================
# Log and temporary files
# ============================================================

*.log
*.tmp
*.temp


# ============================================================
# Raw and processed datasets
#
# Large image datasets are not committed to Git.
# The .gitkeep files preserve the empty folder structure.
# ============================================================

data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep


# ============================================================
# PyTorch model checkpoints
#
# Model weights can be large, so they are excluded by default.
# ============================================================

*.pt
*.pth
*.ckpt